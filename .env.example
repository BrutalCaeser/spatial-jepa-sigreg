# GAP 1 Experiment — Environment Variables
# Copy this to .env and fill in values.
# NEVER commit .env to git (it is in .gitignore).

# ── W&B ──────────────────────────────────────────────────────────────────────
# Get your API key from: https://wandb.ai/settings
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=your_wandb_username_or_team

# ── HPC paths (set on cluster) ────────────────────────────────────────────────
FEATURE_DIR=/scratch/${USER}/data/ssv2_vjepa21_features
OUTPUT_DIR=/scratch/${USER}/outputs/gap1
CHECKPOINT_DIR=/scratch/${USER}/checkpoints

# ── V-JEPA 2.1 checkpoint ─────────────────────────────────────────────────────
VJEPA_CHECKPOINT=/scratch/${USER}/checkpoints/vjepa21_vitg.pt
